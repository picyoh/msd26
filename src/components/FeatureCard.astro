---
const {number, title, description} = Astro.props;
---

<div class="bg-white/5 dark:bg-black/10 backdrop-blur-lg rounded-xl p-6">
    <div
        class="w-12 h-12 bg-gradient-to-r from-blue-500 to-purple-600 rounded-full flex items-center justify-center text-xl font-bold mb-4 mx-auto"
    >
        {number}
    </div>
    <h3 class="text-xl font-semibold mb-2">{title}</h3>
    <p class="text-gray-400">{description}</p>
</div>
