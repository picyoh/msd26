---
import { Icon } from "astro-iconify";
---

<div class="text-center mb-16">
    <h1
        class="text-5xl font-bold mb-6 bg-gradient-to-r from-blue-400 via-purple-500 to-pink-500 text-transparent bg-clip-text"
    >
        Trouvez Votre Souris Idéale
    </h1>
    <p class="text-xl text-gray-300 mb-8">
        Découvrez la souris qui correspond parfaitement à vos besoins
    </p>
    <button
        id="startButton"
        class="bg-gradient-to-r from-blue-500 to-purple-600 px-8 py-4 rounded-full text-lg font-semibold hover:opacity-90 transition-opacity flex items-center gap-2 mx-auto"
    >
        Commencer le Quiz <Icon name="chevron-right-rounded" size={20} />
    </button>
</div>

<script>
    import {quizStarted} from '../store/quizStore'
    const startButton = document.getElementById("startButton");
    startButton?.addEventListener("click", (e) => {
        console.log(e.target);
        quizStarted.set(true);
    });
</script>
