---

function Quiz({ onComplete }: QuizProps) {
  const [currentQuestion, setCurrentQuestion] = useState(0);
  const [answers, setAnswers] = useState<string[]>([]);
  const [showRefinedQuestions, setShowRefinedQuestions] = useState(false);
  const [showRefinedOption, setShowRefinedOption] = useState(false);

  const getQuestions = () => {
    let questions = [...initialQuestions];

    if (answers[0] === "a") {
      // Gaming path
      questions = [
        ...questions.slice(0, 2),
        gamingQuestion,
        gamingObjectiveQuestion,
        gamingHandQuestion,
        ...questions.slice(2)
      ];
      if (showRefinedQuestions) {
        questions = [...questions, ...gamingRefinedQuestions];
      }
    } else if (answers[0] === "b") {
      // Office path
      questions = [
        ...questions.slice(0, 2),
        officeQuestion
      ];

      // Add specific follow-up questions based on office usage type
      if (answers[2] === "a") {
        // Professional
        questions.push(professionalActivityQuestion);
      } else if (answers[2] === "b") {
        // Loisir/Famille
        questions.push(familyPopulationQuestion);
      } else if (answers[2] === "c") {
        // Médical
        questions.push(medicalAspectQuestion);
      }

      // Add the activity question as second follow-up
      questions.push(officeActivityQuestion);

      if (showRefinedQuestions) {
        questions = [...questions, ...officeRefinedQuestions];
      }
    }
    return questions;
  };

  const questions = getQuestions();

  const handleAnswer = (answerId: string) => {
    const newAnswers = [...answers, answerId];
    setAnswers(newAnswers);

    if (currentQuestion === questions.length - 1) {
      if (!showRefinedQuestions) {
        setShowRefinedOption(true);
      } else {
        onComplete(newAnswers);
      }
    } else {
      setCurrentQuestion(currentQuestion + 1);
    }
  };

  const handleRefineSearch = () => {
    setShowRefinedQuestions(true);
    setShowRefinedOption(false);
    const initialQuestionsCount = answers[0] === "a" || answers[0] === "b" ? 5 : initialQuestions.length;
    setCurrentQuestion(initialQuestionsCount);
  };

  const progress = ((currentQuestion + 1) / questions.length) * 100;

  return (
    <div className="container mx-auto px-4 py-12 max-w-2xl">
      <div className="mb-8">
        <div className="h-2 bg-gray-700 rounded-full">
          <div 
            className="h-2 bg-gradient-to-r from-blue-500 to-purple-600 rounded-full transition-all duration-300"
            style={{ width: `${progress}%` }}
          />
        </div>
        <p className="text-gray-400 mt-2">Question {currentQuestion + 1} sur {questions.length}</p>
      </div>

      {showRefinedOption ? (
        <div className="bg-white/10 backdrop-blur-lg rounded-xl p-8">
          <h2 className="text-2xl font-bold mb-6">Voici vos premiers résultats</h2>
          <p className="text-gray-400 mb-8">
            Vous pouvez affiner votre recherche avec 5 questions supplémentaires pour des recommandations plus précises.
          </p>

          <button
            onClick={handleRefineSearch}
            className="w-full text-left px-6 py-4 rounded-lg bg-gradient-to-r from-blue-500 to-purple-600 hover:opacity-90 transition-opacity flex items-center justify-between group mb-8"
          >
            <span className="flex items-center gap-2">
              <Filter size={20} />
              Affiner ma recherche
            </span>
            <ChevronRight className="opacity-100" />
          </button>

          <div className="mt-8">
            <Results 
              results={answers}
              onRestart={() => {
                setCurrentQuestion(0);
                setAnswers([]);
                setShowRefinedQuestions(false);
                setShowRefinedOption(false);
              }}
            />
          </div>
        </div>
      ) : (
        <div className="bg-white/10 backdrop-blur-lg rounded-xl p-8">
          <h2 className="text-2xl font-bold mb-6">{questions[currentQuestion].question}</h2>
          <div className="space-y-4">
            {questions[currentQuestion].options.map((option) => (
              <button
                key={option.id}
                onClick={() => handleAnswer(option.id)}
                className="w-full text-left px-6 py-4 rounded-lg bg-white/5 hover:bg-white/10 transition-colors flex items-center justify-between group"
              >
                <span>{option.text}</span>
                <ChevronRight className="opacity-0 group-hover:opacity-100 transition-opacity" />
              </button>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}