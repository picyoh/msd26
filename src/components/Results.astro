---
import React, { useState } from 'react';
import { RotateCcw, ExternalLink, Star, ChevronLeft, ChevronRight } from 'lucide-react';

interface ResultsProps {
  results: string[];
  onRestart: () => void;
}

interface Mouse {
  name: string;
  brand: string;
  image: string;
  price: string;
  match: number;
  features: string[];
  link: string;
}
---

function Results({ results, onRestart }: ResultsProps) {
  const getRecommendedMice = (): Mouse[] => {
    const isGaming = results[0] === "a";
    const frequency = results[1];
    const usage = results[2];

    if (isGaming) {
      return [
        {
          name: "Logitech G Pro X Superlight",
          brand: "Logitech",
          image: "https://images.unsplash.com/photo-1527814050087-3793815479db?w=400&h=300&fit=crop",
          price: "149€",
          match: 95,
          features: ["Ultra-légère (63g)", "Sans fil", "Capteur HERO 25K", "Ambidextre"],
          link: "#"
        },
        {
          name: "Razer Viper V2 Pro",
          brand: "Razer",
          image: "https://images.unsplash.com/photo-1586920740099-e3379b89c7e9?w=400&h=300&fit=crop",
          price: "139€",
          match: 92,
          features: ["Poids plume (58g)", "Focus Pro 30K", "Switches optiques", "Autonomie 80h"],
          link: "#"
        },
        {
