---

<div class="min-h-screen">
      {!quizStarted && !quizCompleted && (
        <div class="container mx-auto px-4 py-12">
          {/* Hero Section */}
          <div class="text-center mb-16">
            <h1 class="text-5xl font-bold mb-6 bg-gradient-to-r from-blue-400 via-purple-500 to-pink-500 text-transparent bg-clip-text">
              Trouvez Votre Souris Idéale
            </h1>
            <p class="text-xl text-gray-300 mb-8">
              Découvrez la souris qui correspond parfaitement à vos besoins
            </p>
            <button
              onClick={() => setQuizStarted(true)}
              class="bg-gradient-to-r from-blue-500 to-purple-600 px-8 py-4 rounded-full text-lg font-semibold hover:opacity-90 transition-opacity flex items-center gap-2 mx-auto"
            >
              Commencer le Quiz <ChevronRight size={20} />
            </button>
          </div>

          <div class="text-center max-w-4xl mx-auto">
            <h2 class="text-3xl font-bold mb-8">Comment ça marche ?</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
              <FeatureCard
                number="1"
                title="Répondez au quiz"
                description="5 questions simples sur vos besoins"
              />
              <FeatureCard
                number="2"
                title="Analysez vos résultats"
                description="Découvrez les souris recommandées"
              />
              <FeatureCard
                number="3"
                title="Faites votre choix"
                description="Comparez et achetez en toute confiance"
              />
            </div>
          </div>
        </div>
<script>
import { quizStarted } from "../store/quizStore";
import { quizCompleted } from "../store/quizStore";
import { results } from "../store/quizStore";
  const handleRestart = () => {
    quizStarted.set(false);
    quizCompleted.set(false);
    results.set([]);
  };

</script>
