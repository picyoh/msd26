    const saved = localStorage.getItem('darkMode');
    return saved ? JSON.parse(saved) : false;
  }); 
  
 isDark ? 'bg-gradient-to-br from-gray-900 to-gray-800' : 'bg-gradient-to-br from-[#1a1b2e] to-[#2d2d4d]'} text-white`
