---
import Hero from "../components/Hero.astro";
import Feature from "../components/Feature.astro";
import ApprProf from  "../components/AppPro.astro"
// TODO: ChevronRight
// TODO: replace the setX things
// TODO: handle dark mode
// TODO: create FeaturedCard
 /*  const [isDark, setIsDark] = useState(() => {
    const saved = localStorage.getItem('darkMode');
    return saved ? JSON.parse(saved) : false;
  }); 
  
 isDark ? 'bg-gradient-to-br from-gray-900 to-gray-800' : 'bg-gradient-to-br from-[#1a1b2e] to-[#2d2d4d]'} text-white`
  */

---

<div class={`min-h-screen ${isDark ? 'bg-gradient-to-br from-gray-900 to-gray-800' : 'bg-gradient-to-br from-[#1a1b2e] to-[#2d2d4d]'} text-white`}>
      
      {!quizStarted && !quizCompleted && (
        <div class="container mx-auto px-4 py-12">
          <Hero />
          <Feature />
        </div>
      )}

      {quizStarted && !quizCompleted && (
        <>
          <Quiz 
            onComplete={(results) => {
              setResults(results);
              setQuizCompleted(true);
            }}
          />
          <div class="text-center mt-8">
            <button
              onClick={handleRestart}
              class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-gray-600 hover:bg-white/5 transition-colors"
            >
              <RotateCcw size={20} />
              Recommencer le quiz
            </button>
          </div>
        </>
      )}

      {quizCompleted && (
        <Results 
          results={results}
          onRestart={handleRestart}
        />
      )}

      {/* Approche profilaire section */}
     <ApprProf /> 
    </div>

<script>
import { quizStarted } from "../store/quizStore";
import { quizCompleted } from "../store/quizStore";
import { results } from "../store/quizStore";
  const handleRestart = () => {
    quizStarted.set(false);
    quizCompleted.set(false);
    results.set([]);
  };

</script>
